 119:       $Command = $Null
 120:       $MsiMatch = $RxMsiCommand.Match($UninstallString)
 121:       $IsMsiCommand = [System.Boolean]($MsiMatch.Success)
 122: 
 123:       If ($IsMsiCommand -eq $True) {
 124:         $MsiArgsText = [System.String]$MsiMatch.Groups['args'].Value
 125:         $HasUsableMsiArgs = [System.Boolean](
 126:           [System.String]::IsNullOrWhiteSpace($MsiArgsText) -eq $False
 127:         )
 128:         If ($HasUsableMsiArgs -eq $True) {
 129:           $MsiArgs = [System.String](
 130:             $RxMsiInstallFlag.Replace($MsiArgsText, '/X')
 131:           ).Trim()
 132: 
 133:           $HasQuietFlag = [System.Boolean](
 134:             $RxMsiQuietFlag.IsMatch($MsiArgs)
 135:           )
 136:           If ($HasQuietFlag -eq $False) {
 137:             $MsiArgs = '{0} /qn' -f $MsiArgs
 138:           }
 139: 
 140:           $Command = [StartUninstallerUninstallCommand]::new(
 141:             [System.String]('{0}\System32\msiexec.exe' -f $Env:SystemRoot),
 142:             [System.String]$MsiArgs.Trim()
 143:           )
 144:           $Command.PSObject.TypeNames.Insert(0, 'StartUninstaller.UninstallCommand')
 145:         }
 146:       } Else {
 147:         $QuotedBatchMatch = $RxQuotedBatchCommand.Match($UninstallString)
 148:         $UnquotedBatchMatch = $RxUnquotedBatchCommand.Match($UninstallString)
 149:         $BatchMatch = $QuotedBatchMatch
 150:         $HasQuotedBatchMatch = [System.Boolean]($QuotedBatchMatch.Success)
 151:         $HasUnquotedBatchMatch = [System.Boolean]($UnquotedBatchMatch.Success)
 152:         If ($HasQuotedBatchMatch -eq $False -and
 153:             $HasUnquotedBatchMatch -eq $True) {
 154:           $BatchMatch = $UnquotedBatchMatch
 155:         }
 156: 
 157:         $IsBatchCommand = [System.Boolean](
 158:           $HasQuotedBatchMatch -eq $True -or
 159:           $HasUnquotedBatchMatch -eq $True
 160:         )
 161:         If ($IsBatchCommand -eq $True) {
 162:           $Command = [StartUninstallerUninstallCommand]::new(
 163:             [System.String]$BatchMatch.Groups['exe'].Value,
 164:             [System.String]$BatchMatch.Groups['args'].Value
 165:           )
 166:           $Command.PSObject.TypeNames.Insert(0, 'StartUninstaller.UninstallCommand')
 167:         } Else {
 168:           $QuotedExeMatch = $RxQuotedExeCommand.Match($UninstallString)
 169:           $UnquotedExeMatch = $RxUnquotedExeCommand.Match($UninstallString)
 170:           $ExeMatch = $QuotedExeMatch
 171:           $HasQuotedExeMatch = [System.Boolean]($QuotedExeMatch.Success)
 172:           $HasUnquotedExeMatch = [System.Boolean]($UnquotedExeMatch.Success)
 173:           If ($HasQuotedExeMatch -eq $False -and
 174:               $HasUnquotedExeMatch -eq $True) {
 175:             $ExeMatch = $UnquotedExeMatch
 176:           }
 177: 
 178:           $IsExeCommand = [System.Boolean](
 179:             $HasQuotedExeMatch -eq $True -or
 180:             $HasUnquotedExeMatch -eq $True
 181:           )
 182:           If ($IsExeCommand -eq $True) {
 183:             $ExecutableLeaf = [System.IO.Path]::GetFileName(
 184:               [System.String]$ExeMatch.Groups['exe'].Value
 185:             )
 186:             $IsSupportedExecutable = [System.Boolean](
 187:               $UnsupportedExecutables -inotcontains $ExecutableLeaf
 188:             )
 189:             If ($IsSupportedExecutable -eq $True) {
 190:               $HasCustomExeFlags = [System.Boolean](
 191:                 $PSBoundParameters.ContainsKey('EXEFlags') -and
 192:                 $Null -ne $EXEFlags
 193:               )
 194:               $ExeArguments = If ($HasCustomExeFlags -eq $True) {
 195:                 [System.String]$EXEFlags
 196:               } Else {
 197:                 [System.String]$ExeMatch.Groups['args'].Value
 198:               }
 199: 
 200:               $Command = [StartUninstallerUninstallCommand]::new(
 201:                 [System.String]$ExeMatch.Groups['exe'].Value,
 202:                 [System.String]$ExeArguments
 203:               )
 204:               $Command.PSObject.TypeNames.Insert(0, 'StartUninstaller.UninstallCommand')
 205:             }
 206:           }
 207:         }
 208:       }
 209: 
 210:       $Command
 211:     } Catch {
 212:       $ErrorRecord = New-ErrorRecord `
 213:         -ExceptionName:'System.InvalidOperationException' `
 214:         -ExceptionMessage:(
 215:           'Unable to parse uninstall string ''{0}'': {1}' -f
 216:             $UninstallString,
 217:             $PSItem.Exception.Message
 218:         ) `
 219:         -TargetObject:$UninstallString `
 220:         -ErrorId:'ResolveUninstallCommandFailed' `
 221:         -ErrorCategory:([System.Management.Automation.ErrorCategory]::InvalidOperation)
 222:       $PSCmdlet.ThrowTerminatingError($ErrorRecord)
 223:     }
 224:   }
