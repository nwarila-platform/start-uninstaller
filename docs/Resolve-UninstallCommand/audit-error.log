  80:   Process {
  81:     $UnsupportedExecutables = @(
  82:       'cmd.exe',
  83:       'powershell.exe',
  84:       'pwsh.exe',
  85:       'rundll32.exe'
  86:     )
  87: 
  88:     Try {
  89:       $RegexOptions = [System.Text.RegularExpressions.RegexOptions]::IgnoreCase
  90:       $RxMsiInstallFlag = [System.Text.RegularExpressions.Regex]::new(
  91:         '/I(?=\s*[\{"])',
  92:         $RegexOptions
  93:       )
  94:       $RxMsiQuietFlag = [System.Text.RegularExpressions.Regex]::new(
  95:         '(?i)(/quiet\b|/q[nbr]?\b|/passive\b)',
  96:         $RegexOptions
  97:       )
  98:       $RxMsiCommand = [System.Text.RegularExpressions.Regex]::new(
  99:         '^(?:"(?<exe>[^"]*\\)?msiexec(?:\.exe)?"|(?<exe>(?:[^"\s]+\\)?msiexec(?:\.exe)?))\s*(?<args>.*)$',
 100:         $RegexOptions
 101:       )
 102:       $RxQuotedBatchCommand = [System.Text.RegularExpressions.Regex]::new(
 103:         '^"(?<exe>[^"]+\.(?:cmd|bat))"\s*(?<args>.*)$',
 104:         $RegexOptions
 105:       )
 106:       $RxUnquotedBatchCommand = [System.Text.RegularExpressions.Regex]::new(
 107:         '^(?<exe>.+?\.(?:cmd|bat))(?:\s+(?<args>.*))?$',
 108:         $RegexOptions
 109:       )
 110:       $RxQuotedExeCommand = [System.Text.RegularExpressions.Regex]::new(
 111:         '^"(?<exe>[^"]+\.exe)"\s*(?<args>.*)$',
 112:         $RegexOptions
 113:       )
 114:       $RxUnquotedExeCommand = [System.Text.RegularExpressions.Regex]::new(
 115:         '^(?<exe>.+?\.exe)(?:\s+(?<args>.*))?$',
 116:         $RegexOptions
 117:       )
